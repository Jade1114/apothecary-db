# App
PORT=3000
APP_NAME=Apothecary DB

# SQLite
DATABASE_PATH=../data/app.db

# Embedding
# 优先读取 EMBEDDING_API_KEY；如果不填，代码会回退读取 OPENAI_API_KEY
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# LLM
# 优先读取 LLM_API_KEY；如果不填，代码会回退读取 OPENAI_API_KEY
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Shared fallback (可选)
# 如果你想让 embedding 和 llm 共用一个兼容 OpenAI 的 key，可以只填这个
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=profile_chunks
QDRANT_VECTOR_SIZE=1536
